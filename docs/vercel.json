{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "framework": null,
  "github": {
    "autoJobCancelation": false
  },
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/((?!api|css|js|public|components|pages).*)",
      "dest": "/index.html"
    }
  ]
}
